# Normalize all text files to LF in the repository and on checkout.
# Stops the Windows "LF will be replaced by CRLF" warnings (core.autocrlf).
* text=auto eol=lf

# Source / config (LF)
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.svg   text eol=lf

# Binary assets — never apply line-ending conversion.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.mp4   binary
*.pdf   binary
*.keystore binary
*.jks   binary
