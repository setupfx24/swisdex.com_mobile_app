# Mobile-only env. Copy to .env.local and adjust for your dev machine.
# Expo Router reads EXPO_PUBLIC_* at build time and inlines them into the bundle.
# Anything not prefixed EXPO_PUBLIC_ is server-only and NOT available at runtime
# in a managed-workflow build.

# ─── Gateway URLs ────────────────────────────────────────────
# Point at your dev gateway on the LAN. Find your IP with `ipconfig` (Windows)
# or `ifconfig` (macOS/Linux). Physical devices can't reach `localhost` on the
# dev machine — must be the LAN IP.
EXPO_PUBLIC_API_BASE=http://192.168.1.100:8000/api/v1
EXPO_PUBLIC_WS_BASE=ws://192.168.1.100:8000

# ─── Optional: Google Sign-In ────────────────────────────────
# Web client ID from https://console.cloud.google.com/apis/credentials
# (same value as the web trader's NEXT_PUBLIC_GOOGLE_CLIENT_ID). Leave blank
# to hide the "Continue with Google" button on the login screen.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# ─── Optional: Sentry (mobile) ───────────────────────────────
# Separate DSN from the backend so mobile crashes are filterable.
# EXPO_PUBLIC_SENTRY_DSN=

# NOTE: ALLTICK_TOKEN is a BACKEND secret — it belongs in swisdesk/.env,
# NOT here. The mobile app never talks to AllTick directly; it receives
# prices from the gateway's /ws/prices feed. Do not put it in this file.